{
  "permissions": {
    "allow": [
      "Bash(make setup:*)",
      "Bash(make build:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(make fmt:*)",
      "Bash(cargo build:*)",
      "Bash(cargo check:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(bash -n:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)"
    ],
    "ask": [
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(terraform:*)",
      "Bash(psql:*)",
      "Bash(turso:*)",
      "Bash(supabase:*)",
      "Bash(doppler run:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/detect-safety-boundary.sh\"",
            "statusMessage": "safety-boundary check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/detect-scope-creep.sh\"",
            "statusMessage": "scope-creep check"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && printf '%s session end\\n' \"$(date -u +%FT%TZ)\" >> .claude/logs/session.log"
          },
          {
            "type": "command",
            "command": "d=docs/decisions/decision-log.md; if [ -f \"$d\" ]; then last=$(tail -n1 \"$d\"); case \"$last\" in '--- session boundary'*) ;; *) printf -- '\\n--- session boundary %s ---\\n' \"$(date -u +%FT%TZ)\" >> \"$d\";; esac; fi",
            "statusMessage": "decision-log session boundary"
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}/.claude/hooks/detect-unverified-claim.sh\"",
            "statusMessage": "unverified-claim check"
          }
        ]
      }
    ]
  }
}
